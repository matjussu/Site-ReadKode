---
import { getTranslations } from '../../i18n';

interface Props {
  locale?: 'fr' | 'en';
}

const { locale = 'fr' } = Astro.props;
const t = getTranslations(locale);
---

<footer class="bg-bg-code border-t border-white/5">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8 sm:py-12">
    <div class="grid grid-cols-2 sm:grid-cols-2 md:grid-cols-4 gap-6 sm:gap-8">
      <!-- Logo & Tagline -->
      <div class="col-span-2 md:col-span-2">
        <a href={locale === 'fr' ? '/' : '/en'} class="flex items-center gap-2 mb-4">
          <img
            src="/images/logo.png"
            alt="ReadKode"
            class="h-10 w-10"
          />
          <span class="text-2xl font-bold text-text-primary">
            Read<span class="text-logo-slash">/</span><span class="text-logo-bracket">&lt;</span>ode
          </span>
        </a>
        <p class="text-text-secondary text-sm max-w-xs">
          {t.footer.tagline}
        </p>

        <!-- Social Links -->
        <div class="flex gap-4 mt-6">
          <a
            href="https://x.com/ReadKode"
            target="_blank"
            rel="noopener noreferrer"
            class="w-10 h-10 rounded-lg bg-bg-secondary flex items-center justify-center hover:bg-bg-tertiary transition-colors duration-200"
            aria-label="X (Twitter)"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
            </svg>
          </a>
          <a
            href="https://instagram.com/readkode"
            target="_blank"
            rel="noopener noreferrer"
            class="w-10 h-10 rounded-lg bg-bg-secondary flex items-center justify-center hover:bg-bg-tertiary transition-colors duration-200"
            aria-label="Instagram"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
            </svg>
          </a>
          <a
            href="https://tiktok.com/@readkode"
            target="_blank"
            rel="noopener noreferrer"
            class="w-10 h-10 rounded-lg bg-bg-secondary flex items-center justify-center hover:bg-bg-tertiary transition-colors duration-200"
            aria-label="TikTok"
          >
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-5.2 1.74 2.89 2.89 0 012.31-4.64 2.93 2.93 0 01.88.13V9.4a6.84 6.84 0 00-1-.05A6.33 6.33 0 005.8 20.1a6.34 6.34 0 0010.86-4.43v-7a8.16 8.16 0 004.77 1.52v-3.4a4.85 4.85 0 01-1.84-.1z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Links -->
      <div>
        <h4 class="text-text-primary font-semibold mb-4">Links</h4>
        <ul class="space-y-3">
          <li>
            <a href="#features" class="text-text-secondary hover:text-accent transition-colors duration-200 text-sm">
              {t.nav.features}
            </a>
          </li>
          <li>
            <a href="#how-it-works" class="text-text-secondary hover:text-accent transition-colors duration-200 text-sm">
              {t.nav.howItWorks}
            </a>
          </li>
          <li>
            <a href="#waitlist" class="text-text-secondary hover:text-accent transition-colors duration-200 text-sm">
              {t.nav.download}
            </a>
          </li>
        </ul>
      </div>

      <!-- Legal -->
      <div>
        <h4 class="text-text-primary font-semibold mb-4">Legal</h4>
        <ul class="space-y-3">
          <li>
            <a href="/legal" class="text-text-secondary hover:text-accent transition-colors duration-200 text-sm">
              {t.footer.legal}
            </a>
          </li>
          <li>
            <a href="/privacy" class="text-text-secondary hover:text-accent transition-colors duration-200 text-sm">
              {t.footer.privacy}
            </a>
          </li>
          <li>
            <a href="/contact" class="text-text-secondary hover:text-accent transition-colors duration-200 text-sm">
              {t.footer.contact}
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="border-t border-white/5 mt-12 pt-8 flex items-center justify-center">
      <p class="text-text-secondary text-sm">
        {t.footer.copyright}
      </p>
    </div>
  </div>
</footer>
