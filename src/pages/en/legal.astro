---
import Layout from '../../components/layout/Layout.astro';

const locale = 'en';
const title = 'Legal Notice and Terms | ReadKode';
const description = 'Terms of service and legal notice for the ReadKode application.';
---

<Layout title={title} description={description} locale={locale}>
  <section class="px-4 pb-24 pt-28 sm:px-6 sm:pt-32">
    <article class="mx-auto max-w-2xl animate-fade-in">
      <!-- Header -->
      <header>
        <h1 class="text-3xl font-bold tracking-tight text-text-primary sm:text-4xl">
          Terms of Use
        </h1>
        <p class="mt-2 text-sm text-text-secondary">
          Last updated: 16 March 2026
        </p>
      </header>

      <hr class="my-8 border-white/5" />

      <!-- Intro -->
      <p class="leading-relaxed text-[#A1A1A6]">
        These terms of use ("Terms") govern the use of the ReadKode mobile application, a personal project published by a natural person residing in France. By using ReadKode, you accept these Terms without reservation.
      </p>

      <hr class="my-8 border-white/5" />

      <!-- Sections -->
      <div class="space-y-10">
        <section>
          <h2 class="mb-3 flex items-baseline gap-2.5 text-lg font-bold text-text-primary">
            <span aria-hidden="true" class="text-sm font-bold text-warning">01</span>
            Purpose of the app
          </h2>
          <p class="leading-relaxed text-[#A1A1A6]">
            ReadKode is an educational mobile application whose purpose is to teach the reading and understanding of computer code. The app offers interactive exercises, structured lessons, challenges and AI-assisted learning features.
          </p>
        </section>

        <section>
          <h2 class="mb-3 flex items-baseline gap-2.5 text-lg font-bold text-text-primary">
            <span aria-hidden="true" class="text-sm font-bold text-warning">02</span>
            Access to the service
          </h2>
          <p class="leading-relaxed text-[#A1A1A6]">
            The app is available free of charge in guest mode (data stored locally) or through the creation of a user account (cloud sync). We reserve the right to modify, suspend or discontinue all or part of the service at any time, with or without notice.
          </p>
        </section>

        <section>
          <h2 class="mb-3 flex items-baseline gap-2.5 text-lg font-bold text-text-primary">
            <span aria-hidden="true" class="text-sm font-bold text-warning">03</span>
            Account creation
          </h2>
          <p class="mb-3 leading-relaxed text-[#A1A1A6]">
            To create an account, you must provide:
          </p>
          <ul class="space-y-2">
            <li class="flex gap-3 leading-relaxed text-[#A1A1A6]"><span aria-hidden="true" class="mt-[0.6em] h-1.5 w-1.5 shrink-0 rounded-full bg-warning"></span><span>A valid email address</span></li>
            <li class="flex gap-3 leading-relaxed text-[#A1A1A6]"><span aria-hidden="true" class="mt-[0.6em] h-1.5 w-1.5 shrink-0 rounded-full bg-warning"></span><span>A password of at least 6 characters</span></li>
            <li class="flex gap-3 leading-relaxed text-[#A1A1A6]"><span aria-hidden="true" class="mt-[0.6em] h-1.5 w-1.5 shrink-0 rounded-full bg-warning"></span><span>A username</span></li>
          </ul>
          <p class="mt-3 leading-relaxed text-[#A1A1A6]">
            You are responsible for keeping your login credentials confidential and for any activity carried out from your account. In the event of unauthorized use, you must inform us immediately.
          </p>
        </section>

        <section>
          <h2 class="mb-3 flex items-baseline gap-2.5 text-lg font-bold text-text-primary">
            <span aria-hidden="true" class="text-sm font-bold text-warning">04</span>
            User conduct
          </h2>
          <p class="mb-3 leading-relaxed text-[#A1A1A6]">
            By using ReadKode, you agree to:
          </p>
          <ul class="space-y-2">
            <li class="flex gap-3 leading-relaxed text-[#A1A1A6]"><span aria-hidden="true" class="mt-[0.6em] h-1.5 w-1.5 shrink-0 rounded-full bg-warning"></span><span>Use the app in accordance with its educational purpose</span></li>
            <li class="flex gap-3 leading-relaxed text-[#A1A1A6]"><span aria-hidden="true" class="mt-[0.6em] h-1.5 w-1.5 shrink-0 rounded-full bg-warning"></span><span>Not attempt to bypass the app's security mechanisms</span></li>
            <li class="flex gap-3 leading-relaxed text-[#A1A1A6]"><span aria-hidden="true" class="mt-[0.6em] h-1.5 w-1.5 shrink-0 rounded-full bg-warning"></span><span>Not use bots, automated scripts or any other means to manipulate scores, rankings or challenges</span></li>
            <li class="flex gap-3 leading-relaxed text-[#A1A1A6]"><span aria-hidden="true" class="mt-[0.6em] h-1.5 w-1.5 shrink-0 rounded-full bg-warning"></span><span>Not create fake accounts or impersonate another user</span></li>
            <li class="flex gap-3 leading-relaxed text-[#A1A1A6]"><span aria-hidden="true" class="mt-[0.6em] h-1.5 w-1.5 shrink-0 rounded-full bg-warning"></span><span>Respect other users during interactions (duels, rankings)</span></li>
            <li class="flex gap-3 leading-relaxed text-[#A1A1A6]"><span aria-hidden="true" class="mt-[0.6em] h-1.5 w-1.5 shrink-0 rounded-full bg-warning"></span><span>Not attempt to extract, copy or reproduce the app's educational content</span></li>
          </ul>
        </section>

        <section>
          <h2 class="mb-3 flex items-baseline gap-2.5 text-lg font-bold text-text-primary">
            <span aria-hidden="true" class="text-sm font-bold text-warning">05</span>
            Intellectual property
          </h2>
          <p class="mb-3 leading-relaxed text-[#A1A1A6]">
            All ReadKode content is protected by intellectual property law:
          </p>
          <ul class="space-y-2">
            <li class="flex gap-3 leading-relaxed text-[#A1A1A6]"><span aria-hidden="true" class="mt-[0.6em] h-1.5 w-1.5 shrink-0 rounded-full bg-warning"></span><span>The exercises, lessons and educational content are the exclusive property of the publisher of ReadKode</span></li>
            <li class="flex gap-3 leading-relaxed text-[#A1A1A6]"><span aria-hidden="true" class="mt-[0.6em] h-1.5 w-1.5 shrink-0 rounded-full bg-warning"></span><span>The source code, design, icons and animations are protected by copyright</span></li>
            <li class="flex gap-3 leading-relaxed text-[#A1A1A6]"><span aria-hidden="true" class="mt-[0.6em] h-1.5 w-1.5 shrink-0 rounded-full bg-warning"></span><span>The ReadKode brand, logo and associated graphic elements are protected</span></li>
          </ul>
          <p class="mt-3 leading-relaxed text-[#A1A1A6]">
            Any unauthorized reproduction, distribution or modification of the content is strictly prohibited.
          </p>
        </section>

        <section>
          <h2 class="mb-3 flex items-baseline gap-2.5 text-lg font-bold text-text-primary">
            <span aria-hidden="true" class="text-sm font-bold text-warning">06</span>
            Educational content
          </h2>
          <p class="leading-relaxed text-[#A1A1A6]">
            The exercises and lessons are provided for educational purposes only. The code snippets shown in the exercises are designed for learning and do not constitute recommendations for production development practices. ReadKode cannot be held liable for the use of the knowledge gained through the app.
          </p>
        </section>

        <section>
          <h2 class="mb-3 flex items-baseline gap-2.5 text-lg font-bold text-text-primary">
            <span aria-hidden="true" class="text-sm font-bold text-warning">07</span>
            Progression system
          </h2>
          <p class="leading-relaxed text-[#A1A1A6]">
            The app uses a system of experience points (XP), levels and rankings for gamification and motivation purposes. These elements have no monetary value and cannot be exchanged, transferred or cashed in. We reserve the right to change the progression system at any time.
          </p>
        </section>

        <section>
          <h2 class="mb-3 flex items-baseline gap-2.5 text-lg font-bold text-text-primary">
            <span aria-hidden="true" class="text-sm font-bold text-warning">08</span>
            Limitation of liability
          </h2>
          <p class="mb-3 leading-relaxed text-[#A1A1A6]">
            ReadKode is provided "as is". We do not guarantee that the service will be uninterrupted, secure or error-free. Our liability is limited in the following cases:
          </p>
          <ul class="space-y-2">
            <li class="flex gap-3 leading-relaxed text-[#A1A1A6]"><span aria-hidden="true" class="mt-[0.6em] h-1.5 w-1.5 shrink-0 rounded-full bg-warning"></span><span>Loss of progress data in guest mode (local storage only)</span></li>
            <li class="flex gap-3 leading-relaxed text-[#A1A1A6]"><span aria-hidden="true" class="mt-[0.6em] h-1.5 w-1.5 shrink-0 rounded-full bg-warning"></span><span>Temporary unavailability of the service due to maintenance or a technical incident</span></li>
            <li class="flex gap-3 leading-relaxed text-[#A1A1A6]"><span aria-hidden="true" class="mt-[0.6em] h-1.5 w-1.5 shrink-0 rounded-full bg-warning"></span><span>Possible inaccuracies in the educational content</span></li>
            <li class="flex gap-3 leading-relaxed text-[#A1A1A6]"><span aria-hidden="true" class="mt-[0.6em] h-1.5 w-1.5 shrink-0 rounded-full bg-warning"></span><span>Indirect damages related to the use of the app</span></li>
          </ul>
        </section>

        <section>
          <h2 class="mb-3 flex items-baseline gap-2.5 text-lg font-bold text-text-primary">
            <span aria-hidden="true" class="text-sm font-bold text-warning">09</span>
            Suspension and termination
          </h2>
          <p class="mb-3 leading-relaxed text-[#A1A1A6]">
            We reserve the right to suspend or delete your account in the event of a breach of these Terms, in particular in the event of:
          </p>
          <ul class="space-y-2">
            <li class="flex gap-3 leading-relaxed text-[#A1A1A6]"><span aria-hidden="true" class="mt-[0.6em] h-1.5 w-1.5 shrink-0 rounded-full bg-warning"></span><span>Cheating or manipulation of scores and rankings</span></li>
            <li class="flex gap-3 leading-relaxed text-[#A1A1A6]"><span aria-hidden="true" class="mt-[0.6em] h-1.5 w-1.5 shrink-0 rounded-full bg-warning"></span><span>Abusive use of the service</span></li>
            <li class="flex gap-3 leading-relaxed text-[#A1A1A6]"><span aria-hidden="true" class="mt-[0.6em] h-1.5 w-1.5 shrink-0 rounded-full bg-warning"></span><span>Harmful behavior toward other users</span></li>
            <li class="flex gap-3 leading-relaxed text-[#A1A1A6]"><span aria-hidden="true" class="mt-[0.6em] h-1.5 w-1.5 shrink-0 rounded-full bg-warning"></span><span>Violation of intellectual property</span></li>
          </ul>
          <p class="mt-3 leading-relaxed text-[#A1A1A6]">
            You can delete your account at any time from the app's Settings. Deletion results in the permanent erasure of all your data.
          </p>
        </section>

        <section>
          <h2 class="mb-3 flex items-baseline gap-2.5 text-lg font-bold text-text-primary">
            <span aria-hidden="true" class="text-sm font-bold text-warning">10</span>
            Changes to the Terms
          </h2>
          <p class="leading-relaxed text-[#A1A1A6]">
            We reserve the right to amend these Terms at any time. Changes take effect as soon as they are published in the app. By continuing to use ReadKode after a change, you accept the new terms.
          </p>
        </section>

        <section>
          <h2 class="mb-3 flex items-baseline gap-2.5 text-lg font-bold text-text-primary">
            <span aria-hidden="true" class="text-sm font-bold text-warning">11</span>
            Governing law
          </h2>
          <p class="leading-relaxed text-[#A1A1A6]">
            These Terms are governed by French law. In the event of a dispute, and after an attempt at amicable resolution, the competent courts of Paris shall have sole jurisdiction.
          </p>
        </section>
      </div>

      <div class="my-8 rounded-xl border border-warning/20 bg-warning/10 px-5 py-4">
        <p class="font-medium leading-relaxed text-warning">
          By using ReadKode, you acknowledge that you have read, understood and accepted these terms of use in their entirety.
        </p>
      </div>

      <!-- Legal notice -->
      <section>
        <h2 class="mb-3 flex items-baseline gap-2.5 text-lg font-bold text-text-primary">
          <span aria-hidden="true" class="text-sm font-bold text-warning">12</span>
          Legal notice (LCEN)
        </h2>
        <p class="mb-3 leading-relaxed text-[#A1A1A6]">
          In accordance with French law no. 2004-575 of 21 June 2004 on confidence in the digital economy:
        </p>
        <ul class="space-y-2">
          <li class="flex gap-3 leading-relaxed text-[#A1A1A6]"><span aria-hidden="true" class="mt-[0.6em] h-1.5 w-1.5 shrink-0 rounded-full bg-warning"></span><span><strong class="font-semibold text-text-primary">Publisher</strong> : ReadKode, a personal project published by a natural person residing in France (identity provided to the hosting providers in accordance with article 6-III-2 of the LCEN)</span></li>
          <li class="flex gap-3 leading-relaxed text-[#A1A1A6]"><span aria-hidden="true" class="mt-[0.6em] h-1.5 w-1.5 shrink-0 rounded-full bg-warning"></span><span><strong class="font-semibold text-text-primary">Contact</strong> : contact@readkode.com</span></li>
          <li class="flex gap-3 leading-relaxed text-[#A1A1A6]"><span aria-hidden="true" class="mt-[0.6em] h-1.5 w-1.5 shrink-0 rounded-full bg-warning"></span><span><strong class="font-semibold text-text-primary">Web host</strong> : Vercel Inc., 340 S Lemon Ave #4133, Walnut, CA 91789, United States</span></li>
          <li class="flex gap-3 leading-relaxed text-[#A1A1A6]"><span aria-hidden="true" class="mt-[0.6em] h-1.5 w-1.5 shrink-0 rounded-full bg-warning"></span><span><strong class="font-semibold text-text-primary">Domain host</strong> : OVH SAS, 2 rue Kellermann, 59100 Roubaix, France</span></li>
        </ul>
      </section>

      <hr class="my-8 border-white/5" />

      <!-- Contact -->
      <section>
        <h2 class="mb-3 text-lg font-bold text-text-primary">Contact</h2>
        <div class="rounded-2xl border border-white/10 bg-gradient-card p-5">
          <p class="mb-2 text-xs font-bold uppercase tracking-wider text-text-secondary">
            Contact
          </p>
          <a href="mailto:contact@readkode.com" class="font-semibold text-warning transition-colors hover:text-[#FFB340]">
            contact@readkode.com
          </a>
        </div>
      </section>

      <div class="mt-10 text-center text-xs text-text-secondary">
        <p>ReadKode, personal project, France</p>
        <p>France, contact@readkode.com</p>
      </div>
    </article>
  </section>
</Layout>
