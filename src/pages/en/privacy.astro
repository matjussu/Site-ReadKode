---
import Layout from '../../components/layout/Layout.astro';

const locale = 'en';
const title = 'Privacy Policy | ReadKode';
const description = 'ReadKode privacy policy: data we collect, storage, sharing and your GDPR rights.';
---

<Layout title={title} description={description} locale={locale}>
  <section class="px-4 pb-24 pt-28 sm:px-6 sm:pt-32">
    <article class="mx-auto max-w-2xl animate-fade-in">
      <!-- Header -->
      <header>
        <h1 class="text-3xl font-bold tracking-tight text-text-primary sm:text-4xl">
          Privacy Policy
        </h1>
        <p class="mt-2 text-sm text-text-secondary">
          Last updated: 16 March 2026
        </p>
      </header>

      <hr class="my-8 border-white/5" />

      <!-- Intro -->
      <p class="leading-relaxed text-[#A1A1A6]">
        ReadKode ("we", "our", "the app") is a personal project published by a natural person residing in France. We are committed to protecting the privacy of our users. This privacy policy describes how we collect, use and protect your personal data when you use our mobile application.
      </p>

      <div class="my-6 rounded-xl border border-accent/20 bg-accent/10 px-5 py-4">
        <p class="font-medium leading-relaxed text-accent">
          In short: we collect the bare minimum needed to run the app. We never sell your data and never share it with any third party for commercial or advertising purposes.
        </p>
      </div>

      <hr class="my-8 border-white/5" />

      <!-- Sections -->
      <div class="space-y-10">
        <section>
          <h2 class="mb-3 flex items-baseline gap-2.5 text-lg font-bold text-text-primary">
            <span aria-hidden="true" class="text-sm font-bold text-accent">01</span>
            Data we collect
          </h2>
          <p class="mb-3 leading-relaxed text-[#A1A1A6]">
            We only collect the data required to run the app:
          </p>
          <ul class="space-y-2">
            <li class="flex gap-3 leading-relaxed text-[#A1A1A6]"><span aria-hidden="true" class="mt-[0.6em] h-1.5 w-1.5 shrink-0 rounded-full bg-accent"></span><span><strong class="font-semibold text-text-primary">Email address</strong> : for authentication and account recovery</span></li>
            <li class="flex gap-3 leading-relaxed text-[#A1A1A6]"><span aria-hidden="true" class="mt-[0.6em] h-1.5 w-1.5 shrink-0 rounded-full bg-accent"></span><span><strong class="font-semibold text-text-primary">Username</strong> : freely chosen, shown on your profile</span></li>
            <li class="flex gap-3 leading-relaxed text-[#A1A1A6]"><span aria-hidden="true" class="mt-[0.6em] h-1.5 w-1.5 shrink-0 rounded-full bg-accent"></span><span><strong class="font-semibold text-text-primary">Avatar color</strong> : visual personalization of your profile</span></li>
            <li class="flex gap-3 leading-relaxed text-[#A1A1A6]"><span aria-hidden="true" class="mt-[0.6em] h-1.5 w-1.5 shrink-0 rounded-full bg-accent"></span><span><strong class="font-semibold text-text-primary">Learning progress</strong> : completed exercises, XP earned, level, streak, daily activity</span></li>
            <li class="flex gap-3 leading-relaxed text-[#A1A1A6]"><span aria-hidden="true" class="mt-[0.6em] h-1.5 w-1.5 shrink-0 rounded-full bg-accent"></span><span><strong class="font-semibold text-text-primary">Challenge results</strong> : scores and ranking in daily challenges and duels</span></li>
            <li class="flex gap-3 leading-relaxed text-[#A1A1A6]"><span aria-hidden="true" class="mt-[0.6em] h-1.5 w-1.5 shrink-0 rounded-full bg-accent"></span><span><strong class="font-semibold text-text-primary">Anonymized usage data</strong> : pages viewed, in-app interactions (collected via PostHog to improve the service)</span></li>
          </ul>
        </section>

        <section>
          <h2 class="mb-3 flex items-baseline gap-2.5 text-lg font-bold text-text-primary">
            <span aria-hidden="true" class="text-sm font-bold text-accent">02</span>
            Data we do not collect
          </h2>
          <p class="mb-3 leading-relaxed text-[#A1A1A6]">
            We do not collect any of the following data:
          </p>
          <ul class="space-y-2">
            <li class="flex gap-3 leading-relaxed text-[#A1A1A6]"><span aria-hidden="true" class="mt-[0.6em] h-1.5 w-1.5 shrink-0 rounded-full bg-accent"></span><span>Geolocation data</span></li>
            <li class="flex gap-3 leading-relaxed text-[#A1A1A6]"><span aria-hidden="true" class="mt-[0.6em] h-1.5 w-1.5 shrink-0 rounded-full bg-accent"></span><span>Contacts or address book</span></li>
            <li class="flex gap-3 leading-relaxed text-[#A1A1A6]"><span aria-hidden="true" class="mt-[0.6em] h-1.5 w-1.5 shrink-0 rounded-full bg-accent"></span><span>Photos, videos or personal files</span></li>
            <li class="flex gap-3 leading-relaxed text-[#A1A1A6]"><span aria-hidden="true" class="mt-[0.6em] h-1.5 w-1.5 shrink-0 rounded-full bg-accent"></span><span>Browsing history</span></li>
            <li class="flex gap-3 leading-relaxed text-[#A1A1A6]"><span aria-hidden="true" class="mt-[0.6em] h-1.5 w-1.5 shrink-0 rounded-full bg-accent"></span><span>Advertising identifiers</span></li>
            <li class="flex gap-3 leading-relaxed text-[#A1A1A6]"><span aria-hidden="true" class="mt-[0.6em] h-1.5 w-1.5 shrink-0 rounded-full bg-accent"></span><span>Biometric data</span></li>
            <li class="flex gap-3 leading-relaxed text-[#A1A1A6]"><span aria-hidden="true" class="mt-[0.6em] h-1.5 w-1.5 shrink-0 rounded-full bg-accent"></span><span>Payment information</span></li>
          </ul>
        </section>

        <section>
          <h2 class="mb-3 flex items-baseline gap-2.5 text-lg font-bold text-text-primary">
            <span aria-hidden="true" class="text-sm font-bold text-accent">03</span>
            How we use your data
          </h2>
          <p class="mb-3 leading-relaxed text-[#A1A1A6]">
            Your data is used exclusively to:
          </p>
          <ul class="space-y-2">
            <li class="flex gap-3 leading-relaxed text-[#A1A1A6]"><span aria-hidden="true" class="mt-[0.6em] h-1.5 w-1.5 shrink-0 rounded-full bg-accent"></span><span>Let you sign in to your account on all your devices</span></li>
            <li class="flex gap-3 leading-relaxed text-[#A1A1A6]"><span aria-hidden="true" class="mt-[0.6em] h-1.5 w-1.5 shrink-0 rounded-full bg-accent"></span><span>Save and sync your learning progress</span></li>
            <li class="flex gap-3 leading-relaxed text-[#A1A1A6]"><span aria-hidden="true" class="mt-[0.6em] h-1.5 w-1.5 shrink-0 rounded-full bg-accent"></span><span>Display your profile and statistics</span></li>
            <li class="flex gap-3 leading-relaxed text-[#A1A1A6]"><span aria-hidden="true" class="mt-[0.6em] h-1.5 w-1.5 shrink-0 rounded-full bg-accent"></span><span>Manage the leaderboard and challenge results</span></li>
            <li class="flex gap-3 leading-relaxed text-[#A1A1A6]"><span aria-hidden="true" class="mt-[0.6em] h-1.5 w-1.5 shrink-0 rounded-full bg-accent"></span><span>Improve the user experience of the app</span></li>
          </ul>
        </section>

        <section>
          <h2 class="mb-3 flex items-baseline gap-2.5 text-lg font-bold text-text-primary">
            <span aria-hidden="true" class="text-sm font-bold text-accent">04</span>
            Storage and security
          </h2>
          <p class="mb-3 leading-relaxed text-[#A1A1A6]">
            Your data is stored securely on Google Firebase servers, located in the Europe region (europe-west9, Paris). We use industry-standard security protocols:
          </p>
          <ul class="space-y-2">
            <li class="flex gap-3 leading-relaxed text-[#A1A1A6]"><span aria-hidden="true" class="mt-[0.6em] h-1.5 w-1.5 shrink-0 rounded-full bg-accent"></span><span>Encryption of data in transit (TLS/SSL)</span></li>
            <li class="flex gap-3 leading-relaxed text-[#A1A1A6]"><span aria-hidden="true" class="mt-[0.6em] h-1.5 w-1.5 shrink-0 rounded-full bg-accent"></span><span>Encryption of data at rest</span></li>
            <li class="flex gap-3 leading-relaxed text-[#A1A1A6]"><span aria-hidden="true" class="mt-[0.6em] h-1.5 w-1.5 shrink-0 rounded-full bg-accent"></span><span>Firestore security rules for data access</span></li>
            <li class="flex gap-3 leading-relaxed text-[#A1A1A6]"><span aria-hidden="true" class="mt-[0.6em] h-1.5 w-1.5 shrink-0 rounded-full bg-accent"></span><span>Firebase authentication with password hashing</span></li>
            <li class="flex gap-3 leading-relaxed text-[#A1A1A6]"><span aria-hidden="true" class="mt-[0.6em] h-1.5 w-1.5 shrink-0 rounded-full bg-accent"></span><span>Rate limiting on sign-in attempts</span></li>
          </ul>
        </section>

        <section>
          <h2 class="mb-3 flex items-baseline gap-2.5 text-lg font-bold text-text-primary">
            <span aria-hidden="true" class="text-sm font-bold text-accent">05</span>
            Data sharing
          </h2>
          <div class="mb-4 rounded-xl border border-accent/20 bg-accent/10 px-5 py-4">
            <p class="font-medium leading-relaxed text-accent">
              We never sell, rent or share your personal data with third parties for commercial or advertising purposes.
            </p>
          </div>
          <p class="mb-3 leading-relaxed text-[#A1A1A6]">
            The only third parties with access to your data are the technical providers required to run the app:
          </p>
          <ul class="space-y-2">
            <li class="flex gap-3 leading-relaxed text-[#A1A1A6]"><span aria-hidden="true" class="mt-[0.6em] h-1.5 w-1.5 shrink-0 rounded-full bg-accent"></span><span><strong class="font-semibold text-text-primary">Firebase (Google)</strong> : authentication and database (Europe region, europe-west9)</span></li>
            <li class="flex gap-3 leading-relaxed text-[#A1A1A6]"><span aria-hidden="true" class="mt-[0.6em] h-1.5 w-1.5 shrink-0 rounded-full bg-accent"></span><span><strong class="font-semibold text-text-primary">Vercel</strong> : web application hosting</span></li>
            <li class="flex gap-3 leading-relaxed text-[#A1A1A6]"><span aria-hidden="true" class="mt-[0.6em] h-1.5 w-1.5 shrink-0 rounded-full bg-accent"></span><span><strong class="font-semibold text-text-primary">PostHog</strong> : analytics and audience measurement (anonymized data)</span></li>
            <li class="flex gap-3 leading-relaxed text-[#A1A1A6]"><span aria-hidden="true" class="mt-[0.6em] h-1.5 w-1.5 shrink-0 rounded-full bg-accent"></span><span><strong class="font-semibold text-text-primary">OVH</strong> : hosting of the readkode.com domain name</span></li>
          </ul>
          <p class="mt-3 leading-relaxed text-[#A1A1A6]">
            These providers are subject to their own privacy policies and comply with the GDPR.
          </p>
        </section>

        <section>
          <h2 class="mb-3 flex items-baseline gap-2.5 text-lg font-bold text-text-primary">
            <span aria-hidden="true" class="text-sm font-bold text-accent">06</span>
            Guest mode
          </h2>
          <p class="leading-relaxed text-[#A1A1A6]">
            You can use ReadKode without creating an account. In guest mode, your progress data is stored only on your device (localStorage) and is not sent to our servers. No personal data is collected in guest mode.
          </p>
        </section>

        <section>
          <h2 class="mb-3 flex items-baseline gap-2.5 text-lg font-bold text-text-primary">
            <span aria-hidden="true" class="text-sm font-bold text-accent">07</span>
            Your rights (GDPR)
          </h2>
          <p class="mb-3 leading-relaxed text-[#A1A1A6]">
            Under the General Data Protection Regulation (GDPR), you have the following rights:
          </p>
          <ul class="space-y-2">
            <li class="flex gap-3 leading-relaxed text-[#A1A1A6]"><span aria-hidden="true" class="mt-[0.6em] h-1.5 w-1.5 shrink-0 rounded-full bg-accent"></span><span><strong class="font-semibold text-text-primary">Right of access</strong> : view all the data we hold about you</span></li>
            <li class="flex gap-3 leading-relaxed text-[#A1A1A6]"><span aria-hidden="true" class="mt-[0.6em] h-1.5 w-1.5 shrink-0 rounded-full bg-accent"></span><span><strong class="font-semibold text-text-primary">Right to rectification</strong> : edit your personal information</span></li>
            <li class="flex gap-3 leading-relaxed text-[#A1A1A6]"><span aria-hidden="true" class="mt-[0.6em] h-1.5 w-1.5 shrink-0 rounded-full bg-accent"></span><span><strong class="font-semibold text-text-primary">Right to erasure</strong> : delete your account and all your data via Settings &gt; Delete account</span></li>
            <li class="flex gap-3 leading-relaxed text-[#A1A1A6]"><span aria-hidden="true" class="mt-[0.6em] h-1.5 w-1.5 shrink-0 rounded-full bg-accent"></span><span><strong class="font-semibold text-text-primary">Right to portability</strong> : obtain a copy of your data in a readable format</span></li>
            <li class="flex gap-3 leading-relaxed text-[#A1A1A6]"><span aria-hidden="true" class="mt-[0.6em] h-1.5 w-1.5 shrink-0 rounded-full bg-accent"></span><span><strong class="font-semibold text-text-primary">Right to object</strong> : object to the processing of your data</span></li>
          </ul>
          <p class="mt-3 leading-relaxed text-[#A1A1A6]">
            To exercise these rights, contact us at the address below.
          </p>
        </section>

        <section>
          <h2 class="mb-3 flex items-baseline gap-2.5 text-lg font-bold text-text-primary">
            <span aria-hidden="true" class="text-sm font-bold text-accent">08</span>
            Data retention
          </h2>
          <p class="leading-relaxed text-[#A1A1A6]">
            Your data is kept as long as your account is active. If you delete your account, all your personal data and progress are permanently removed from our servers within 30 days.
          </p>
        </section>

        <section>
          <h2 class="mb-3 flex items-baseline gap-2.5 text-lg font-bold text-text-primary">
            <span aria-hidden="true" class="text-sm font-bold text-accent">09</span>
            Minors
          </h2>
          <p class="leading-relaxed text-[#A1A1A6]">
            ReadKode is accessible to all ages. For users under 16, the consent of a parent or legal guardian is required to create an account, in accordance with the GDPR.
          </p>
        </section>

        <section>
          <h2 class="mb-3 flex items-baseline gap-2.5 text-lg font-bold text-text-primary">
            <span aria-hidden="true" class="text-sm font-bold text-accent">10</span>
            Changes
          </h2>
          <p class="leading-relaxed text-[#A1A1A6]">
            We reserve the right to amend this privacy policy. In the event of a material change, you will be informed via an in-app notification. The last updated date is shown at the top of this document.
          </p>
        </section>
      </div>

      <hr class="my-8 border-white/5" />

      <!-- Contact -->
      <section>
        <h2 class="mb-3 text-lg font-bold text-text-primary">Contact</h2>
        <div class="rounded-2xl border border-white/10 bg-gradient-card p-5">
          <p class="mb-2 text-xs font-bold uppercase tracking-wider text-text-secondary">
            Data controller
          </p>
          <a href="mailto:contact@readkode.com" class="font-semibold text-accent transition-colors hover:text-accent-light">
            contact@readkode.com
          </a>
        </div>
      </section>

      <div class="mt-10 text-center text-xs text-text-secondary">
        <p>ReadKode, personal project, France</p>
        <p>France, contact@readkode.com</p>
      </div>
    </article>
  </section>
</Layout>
